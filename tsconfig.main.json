{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": "./dist_electron",
    "rootDir": "./src/main",
    "types": ["electron", "node"],
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": ["src/main/**/*.ts"]
}
